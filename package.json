{
  "name": "personal-knowledge-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Household knowledge base MCP server (Phase 1: LAN-only foundation)",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "pk-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^11.10.0",
    "express": "^5.1.0",
    "sqlite-vec": "^0.1.7-alpha.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.0",
    "@types/node": "^22.15.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
