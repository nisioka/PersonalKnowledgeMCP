[Unit]
Description=Personal Knowledge Discord ingestion bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pk
WorkingDirectory=/opt/personal-knowledge-mcp
EnvironmentFile=/opt/personal-knowledge-mcp/.env
ExecStart=/usr/bin/node dist/ingest/discord.js
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
