# Personal Knowledge MCP — environment configuration.
# Copy to .env and adjust. Most values are optional; sensible defaults apply.

# ── MCP server (Phase 1) ────────────────────────────────────────────────────
# Bind address. Default 127.0.0.1 (loopback only). Set 0.0.0.0 for LAN access.
# PK_HOST=0.0.0.0
# PK_PORT=8848
# PK_DB_PATH=data/knowledge.db
# Embedding vector dimension. Fixed at DB creation; changing needs a fresh DB.
# PK_EMBEDDING_DIM=256

# Token -> principal registry (JSON). Unset => built-in DEV tokens (LAN only).
# `shared` is added to every principal automatically.
# PK_TOKENS={"<full-secret>":{"name":"full","scopes":["private","work","shared"],"defaultWriteScope":"private"},"<work-secret>":{"name":"work","scopes":["work","shared"]},"<family-secret>":{"name":"family","scopes":["shared"]}}

# ── Cloudflare Access (Phase 3) ──────────────────────────────────────────────
# Trust the Cf-Access-Authenticated-User-Email header (only behind Access!).
# PK_TRUST_ACCESS_HEADER=true
# Authenticated email -> principal (same shape as PK_TOKENS, keyed by email).
# PK_ACCESS_EMAILS={"you@example.com":{"name":"full","scopes":["private","work","shared"]},"partner@example.com":{"name":"family","scopes":["shared"]}}

# Document ingestion uses Claude itself (no API key): attach a file in Claude
# (Code / Desktop / app, or a Claude Code Discord bridge) and run the MCP prompt
# `ingest_document` — Claude reads it and calls `register`. No extra env needed.

# ── Encrypted Google Drive backup (Phase 2, §9.2) ────────────────────────────
# PK_BACKUP_PASSPHRASE=...        # required for backup/restore
# PK_BACKUP_FOLDER_ID=...         # Google Drive folder id
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Proactive reminders (Phase 4, §4) ────────────────────────────────────────
# PK_REMINDER_DAYS=14
# PK_REMINDER_WEBHOOK=https://discord.com/api/webhooks/...
