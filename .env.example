# Personal Knowledge MCP — environment configuration (Phase 1)
# Copy to .env and adjust. All values are optional; sensible defaults apply.

# Bind address. Default 127.0.0.1 (loopback only). Set to 0.0.0.0 to accept
# LAN connections from the main machine's Claude Code (design §5/§6).
# PK_HOST=0.0.0.0

# Port the Streamable HTTP server listens on.
# PK_PORT=8848

# Path to the SQLite knowledge store (created if missing).
# PK_DB_PATH=data/knowledge.db

# Embedding vector dimension. Fixed at DB creation time — changing it later
# requires a fresh DB (or a migration).
# PK_EMBEDDING_DIM=256

# Token -> principal registry as JSON. When unset, built-in DEV tokens are used
# (full-dev-token / work-dev-token / family-dev-token) — LAN bring-up only.
# `shared` is added to every principal automatically.
# PK_TOKENS={"<full-secret>":{"name":"full","scopes":["private","work","shared"],"defaultWriteScope":"private"},"<work-secret>":{"name":"work","scopes":["work","shared"]},"<family-secret>":{"name":"family","scopes":["shared"]}}
